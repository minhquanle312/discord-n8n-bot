      "parameters": {
        "jsCode": "const body = $json.body ?? {};\nconst command = body.command ?? null;\n\nif (command === 'receipt') {\n  const imageUrl = body.receipt?.url;\n  const contentType = body.receipt?.contentType ?? '';\n\n  if (!imageUrl) {\n    return [{ json: { route: 'invalid', error_code: 'MISSING_RECEIPT_URL', message: 'receipt.url is required for the receipt workflow.' } }];\n  }\n\n  if (contentType && !contentType.startsWith('image/')) {\n    return [{ json: { route: 'invalid', error_code: 'INVALID_RECEIPT_CONTENT_TYPE', message: 'receipt.contentType must be an image/* mime type.' } }];\n  }\n\n  return [{ json: { ...$json, route: 'receipt' } }];\n}\n\nif (command === 'out') {\n  return [{ json: { ...$json, route: 'outcome' } }];\n}\n\nreturn [{ json: { route: 'invalid', error_code: 'UNSUPPORTED_COMMAND', message: 'Only the receipt command is supported by this webhook path.' } }];"
      },
